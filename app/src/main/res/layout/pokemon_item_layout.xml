<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="30dp" android:layout_marginEnd="30dp" android:layout_marginTop="10dp" android:layout_marginVertical="10dp" android:layout_marginHorizontal="10dp" app:cardCornerRadius="10dp" app:cardElevation="20dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">

        <TextView
            android:layout_width="140dp"
            android:layout_height="30dp"
            android:id="@+id/pokemonName"
            android:text="Pokemon"
            android:textColor="?android:attr/textColor"
            android:textSize="20sp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="5dp" />

        <RelativeLayout
            android:id="@+id/check_layout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/pokemonName"
            android:gravity="center">

            <CheckBox
                android:id="@+id/check1"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="15dp"
                android:button="@null"
                android:background="@drawable/pokeball_check"
                tools:ignore="TouchTargetSizeCheck"/>

            <CheckBox
                android:id="@+id/check2"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:layout_toEndOf="@id/check1"
                android:button="@null"
                android:background="@drawable/pokeball_check"
                tools:ignore="TouchTargetSizeCheck" />

            <CheckBox
                android:id="@+id/check3"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_toEndOf="@id/check2"
                android:scaleX="1"
                android:scaleY="1"
                android:button="@null"
                android:background="@drawable/pokeball_check"
                tools:ignore="TouchTargetSizeCheck" />

        </RelativeLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>